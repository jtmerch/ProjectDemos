@page "/"
@using PaymentBlazorClient.DTOs
@inject PaymentBlazorClient.Services.PaymentGatewayClient GatewayClient

<div class="card shadow-sm mb-4">
    <div class="card-header">
        <h5 class="mb-0">Authorize Payment</h5>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-sm-6">
                <label class="form-label">Merchant ID</label>
                <input class="form-control" @bind="request.MerchantId" />
            </div>
            <div class="col-sm-4">
                <label class="form-label">Amount</label>
                <input class="form-control" type="number" step="0.01" @bind="request.Amount" />
            </div>
            <div class="col-sm-2">
                <label class="form-label">Currency</label>
                <input class="form-control" @bind="request.Currency" />
            </div>
            <div class="col-sm-12">
                <label class="form-label">Card Number</label>
                <input class="form-control" @bind="request.CardNumber" />
            </div>
            <div class="col-sm-4">
                <label class="form-label">Exp. Month</label>
                <input class="form-control" type="number" @bind="request.ExpirationMonth" />
            </div>
            <div class="col-sm-4">
                <label class="form-label">Exp. Year</label>
                <input class="form-control" type="number" @bind="request.ExpirationYear" />
            </div>
            <div class="col-sm-4">
                <label class="form-label">CVV</label>
                <input class="form-control" @bind="request.CVV" />
            </div>
            <div class="col-sm-12">
                <label class="form-label">Customer Name</label>
                <input class="form-control" @bind="request.CustomerName" />
            </div>
        </div>
        <button class="btn btn-primary mt-4 w-100" @onclick="Authorize" disabled="@isLoading">
            @if (isLoading)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                <span>Processing...</span>
            }
            else
            {
                <span>Authorize</span>
            }
        </button>
    </div>
</div>

@if (response != null)
{
    <div class="alert @(response.Approved ? "alert-success" : "alert-danger") d-flex align-items-center" role="alert">
        <strong class="me-2">@(response.Approved ? "Approved" : "Declined")</strong>
        @response.ResponseMessage
    </div>

    <div class="card shadow-sm">
        <div class="card-header">Authorization Details</div>
        <ul class="list-group list-group-flush">
            <li class="list-group-item d-flex justify-content-between">
                <span class="text-muted">Transaction ID</span>
                <span class="fw-semibold font-monospace">@response.TransactionId</span>
            </li>
            <li class="list-group-item d-flex justify-content-between">
                <span class="text-muted">Auth Code</span>
                <span class="fw-semibold font-monospace">@(string.IsNullOrEmpty(response.AuthCode) ? "—" : response.AuthCode)</span>
            </li>
            <li class="list-group-item d-flex justify-content-between">
                <span class="text-muted">Processor Response</span>
                <span class="fw-semibold">@response.ProcessorResponseCode</span>
            </li>
            <li class="list-group-item d-flex justify-content-between">
                <span class="text-muted">Merchant</span>
                <span>@response.MerchantName</span>
            </li>
            <li class="list-group-item d-flex justify-content-between">
                <span class="text-muted">Processor</span>
                <span>@response.ProcessorName</span>
            </li>
            <li class="list-group-item d-flex justify-content-between">
                <span class="text-muted">Fraud Score</span>
                <span class="badge @(response.FraudScore >= 80 ? "bg-danger" : response.FraudScore >= 50 ? "bg-warning text-dark" : "bg-success")">
                    @response.FraudScore
                </span>
            </li>
        </ul>
    </div>
}

@code {
    private CardPaymentRequest request = new CardPaymentRequest();
    private PaymentAuthorizationResponse? response;
    private bool isLoading;

    private async Task Authorize()
    {
        isLoading = true;
        request.IdempotencyKey = Guid.NewGuid().ToString();
        response = await GatewayClient.AuthorizeAsync(request);
        isLoading = false;
    }
}
