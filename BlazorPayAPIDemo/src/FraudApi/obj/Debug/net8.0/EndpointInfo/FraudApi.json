{
  "openapi": "3.0.1",
  "info": {
    "title": "FraudApi",
    "version": "1.0"
  },
  "paths": {
    "/api/Fraud/check": {
      "post": {
        "tags": [
          "Fraud"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FraudCheckRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/FraudCheckRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/FraudCheckRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/FraudResult"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FraudResult"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/FraudResult"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FraudCheckRequest": {
        "type": "object",
        "properties": {
          "merchantId": {
            "type": "string",
            "nullable": true
          },
          "amount": {
            "type": "number",
            "format": "double"
          },
          "customerName": {
            "type": "string",
            "nullable": true
          },
          "cardNumber": {
            "type": "string",
            "nullable": true
          },
          "riskLevel": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "FraudResult": {
        "type": "object",
        "properties": {
          "fraudScore": {
            "type": "integer",
            "format": "int32"
          },
          "recommendation": {
            "type": "string",
            "nullable": true
          },
          "message": {
            "type": "string",
            "nullable": true
          },
          "cardNetwork": {
            "type": "string",
            "nullable": true
          },
          "velocityFlag": {
            "type": "boolean"
          },
          "checksPerformed": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}