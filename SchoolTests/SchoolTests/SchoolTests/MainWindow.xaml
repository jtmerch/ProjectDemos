<Window x:Class="SchoolTests.MainWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        Title="School Tests" Height="800" Width="1300"
        WindowStyle="None" Topmost="True" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <WindowsFormsHost Name="host">
            <wf:WebBrowser x:Name="webBrowser1" />
        </WindowsFormsHost>
        <WindowsFormsHost Name="button2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0" >
            <wf:Button Text="End Session" x:Name="btnEnd" Width="110" Height="35" TextAlign="MiddleRight" ImageAlign="MiddleLeft" FlatStyle="Flat" />
        </WindowsFormsHost>
        <WindowsFormsHost Name="label1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,10" >
            <wf:Label Text="10:00" x:Name="lblTime" />
        </WindowsFormsHost>
        <Button Height="65" Margin="0,0,0,0" Name="button1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="198" Click="button1_Click">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image Source="newsession.png" Margin="5" Grid.Column="0" />
                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="Begin Test" FontWeight="Bold" />
                    <TextBlock Text="You are allowed to test for 10 minutes."
                       TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Button>
        <TextBox Name="uxTestPin" HorizontalAlignment="Left" Height="23" Margin="164,103,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="198"/>
        <Label FontWeight="Bold" Content="Enter the test pin:" HorizontalAlignment="Left" Margin="164,72,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.332,-1.019" Width="138" Name="PinLabel"/>
    </Grid>
</Window>
